APP_ENV=development
APP_API_KEY=
KB_SERVICE_SECRET=change_me_internal_service_secret
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REQUIRE_AI_SERVICE=false

SF_API_KEY=
SF_BASE_URL=
AL_BAILIAN_API_KEY=
AL_BAILIAN_BASE_URL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=

# Phase 1 文件发现探索 agent（project_analysis_agent_upgrade_plan.md）。
# 留空则该 agent 退化为纯启发式 detection_signature 关键词匹配，不调用任何模型。
# 待确认：SF_/AL_BAILIAN_ 渠道能否直接跑 deepseek 系列模型，还是需要新增供应商适配。
EXPLORATION_MODEL_NAME=
EXPLORATION_API_KEY=
EXPLORATION_BASE_URL=

# 项目回答规则守卫（harness_guard）真实拦截开关，默认 false 保持现有生产行为。
# 打开后会对回答做确定性短语级拦截/替换，仅供本地/预发验证，不等同于恢复历史上的语义级守卫。
HARNESS_GUARD_ENFORCEMENT_ENABLED=false

# Phase 1.1 代码语义解析 agent（project_analysis_agent_upgrade_plan.md）。
# 留空则只跑静态规则提取（正则匹配已知公式变体的变量名），不调用任何模型。
CODE_SEMANTICS_MODEL_NAME=
CODE_SEMANTICS_API_KEY=
CODE_SEMANTICS_BASE_URL=

# Semicolon-separated local roots and/or SFTP URLs.
PROJECT_BASE_DIRS=
PROJECT_SOP_BASE_DIRS=
PROJECT_SFTP_CACHE_DIR=
PROJECT_SFTP_OFFLINE=0
PROJECT_ENFORCE_ROOT_ALLOWLIST=0
PROJECT_WORKSPACE_DIR=
