# Docker 环境配置模板 —— 复制为 .env 后填入真实值
# cp multi_agent/backed/app/.env.docker multi_agent/backed/app/.env

APP_ENV=production
APP_API_KEY=your_strong_api_key_here   # 生产必须非空
KB_SERVICE_SECRET=change_me_internal_service_secret

CORS_ALLOW_ORIGINS=http://your-domain.com,https://your-domain.com

# ── LLM 配置（至少填一个）────────────────────────────────────────────────────
SF_API_KEY=
SF_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

AL_BAILIAN_API_KEY=
AL_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

MAIN_MODEL_NAME=deepseek-v4-flash
SUB_MODEL_NAME=deepseek-v4-flash
REPORT_SUMMARY_MODEL_NAME=deepseek-v4-flash

# ── MCP 联网搜索 ──────────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp
BAIDUMAP_AK=

# ── MySQL（MYSQL_HOST 在 docker-compose 中已覆盖为 mysql）────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=appuser
MYSQL_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=nvz
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10
MYSQL_MAX_CONNECTIONS=5

# ── 知识库（同网络内另一服务时保持默认）─────────────────────────────────────
KNOWLEDGE_BASE_URL=http://knowledge:8001

# ── 项目文件读取 ──────────────────────────────────────────────────────────────
# SFTP 格式：sftp://user@host:22/path
PROJECT_BASE_DIRS=sftp://wangzk@10.11.0.16:22/beegfs/Pipline_cloud/data_cloud/Result
PROJECT_SEARCH_DEPTH=2
PROJECT_SFTP_OFFLINE=0
PROJECT_SFTP_CACHE_DIR=/app/multi_agent/backed/app/.project_sftp_cache
